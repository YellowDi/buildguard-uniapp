{
  "lazyCodeLoading": "requiredComponents",
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/inspection/index",
      "style": {
        "navigationStyle": "custom",
        "componentPlaceholder": {
          "base-sheet": "view"
        }
      }
    },
    {
      "path": "pages/task-detail/index",
      "style": {
        "navigationStyle": "custom",
        "componentPlaceholder": {
          "base-sheet": "view",
          "inspection-editor-sheet": "view",
          "task-report-sheet": "view"
        }
      }
    },
    {
      "path": "pages/maintenance/index",
      "style": {
        "navigationStyle": "custom",
        "componentPlaceholder": {
          "base-sheet": "view"
        }
      }
    },
    {
      "path": "pages/maintenance-detail/index",
      "style": {
        "navigationStyle": "custom",
        "componentPlaceholder": {
          "maintenance-execution-sheet": "view",
          "maintenance-result-sheet": "view"
        }
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "BuildGuard",
    "backgroundColor": "#EBEBEB"
  }
}
