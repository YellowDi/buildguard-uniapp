{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["@dcloudio/types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/App.vue",
    "src/main.ts",
    "src/pages/**/*.vue",
    "src/components/**/*.vue",
    "src/shared/**/*.ts",
    "src/shared/**/*.json",
    "src/services/**/*.ts",
    "src/env.d.ts"
  ]
}
